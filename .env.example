# ═════════════════════════════════════════════════════════════════════
# Environment Variables Example
# คัดลอกไฟล์นี้เป็น .env แล้วกรอกค่าจริง (ห้าม commit .env เข้า git)
# ═════════════════════════════════════════════════════════════════════

# Finnhub API Token (https://finnhub.io/dashboard)
FINNHUB_TOKEN=your_finnhub_token_here

# Producer config (optional — มีค่า default แล้ว)
MAX_ROWS_PER_RUN=5000
SEND_INTERVAL=5
MAX_SYMBOLS=50

# Infrastructure (optional — ปกติไม่ต้องแก้)
MONGO_URI=mongodb://mongodb:27017/
KAFKA_BROKER=kafka:29092
