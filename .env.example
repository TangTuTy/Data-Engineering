# Finnhub API Token (https://finnhub.io/dashboard)
FINNHUB_TOKEN=your_finnhub_token_here

# Discord Webhook สำหรับ alert (optional — ถ้าไม่ตั้ง alert จะไม่ส่ง)
# วิธีสร้าง: Discord channel → Edit Channel → Integrations → Webhooks → New Webhook
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy

